{
  "name": "agentreview",
  "version": "0.1.0",
  "description": "Multi-perspective automated PR review CLI using parallel AI agents",
  "bin": {
    "agentreview": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@octokit/rest": "^20.1.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "openai": "^4.56.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pr-review",
    "ai",
    "code-review",
    "github",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "author": "Vidya <https://github.com/vidyasagarr7>",
  "repository": {
    "type": "git",
    "url": "https://github.com/vidyasagarr7/agentreview.git"
  },
  "homepage": "https://github.com/vidyasagarr7/agentreview#readme",
  "bugs": {
    "url": "https://github.com/vidyasagarr7/agentreview/issues"
  }
}
