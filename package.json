{
  "name": "agentreview",
  "version": "1.0.0",
  "description": "Multi-perspective automated PR review CLI using parallel AI agents",
  "bin": {
    "agentreview": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsc --noEmit && vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build:action": "tsup --config tsup.config.action.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@google/genai": "^2.5.0",
    "@octokit/rest": "^20.1.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "minimatch": "^10.2.5",
    "openai": "^4.56.0",
    "ora": "^8.1.0",
    "p-limit": "^7.3.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pr-review",
    "ai",
    "code-review",
    "github",
    "cli"
  ],
  "license": "MIT",
  "type": "module",
  "author": "Vidya <https://github.com/vidyasagarr7>",
  "repository": {
    "type": "git",
    "url": "https://github.com/vidyasagarr7/agentreview.git"
  },
  "homepage": "https://github.com/vidyasagarr7/agentreview#readme",
  "bugs": {
    "url": "https://github.com/vidyasagarr7/agentreview/issues"
  }
}
